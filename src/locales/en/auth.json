{
  "signUp": {
    "title": "Create an account",
    "subtitle": "Get started today",
    "fields": {
      "name": {
        "label": "Full name",
        "placeholder": "John Doe"
      },
      "email": {
        "label": "Email",
        "placeholder": "you@example.com"
      },
      "password": {
        "label": "Password",
        "placeholder": "••••••••"
      },
      "confirmPassword": {
        "label": "Confirm password",
        "placeholder": "••••••••"
      }
    },
    "submit": "Create account",
    "submitting": "Creating account…",
    "toast": {
      "loading": "Creating account…",
      "success": "Account created successfully!",
      "error": "Error creating account: {{error}}"
    },
    "footer": {
      "text": "Already have an account?",
      "link": "Sign in"
    }
  },
  "signIn": {
    "title": "Welcome back",
    "subtitle": "Sign in to your account to continue",
    "fields": {
      "email": {
        "label": "Email",
        "placeholder": "you@example.com"
      },
      "password": {
        "label": "Password",
        "placeholder": "••••••••",
        "forgotPassword": "Forgot password?"
      }
    },
    "submit": "Sign in",
    "submitting": "Signing in…",
    "toast": {
      "loading": "Signing in…",
      "success": "Welcome back, {{identifier}}!",
      "error": "Error signing in: {{error}}",
      "needsVerification": "Account not verified. Redirecting to verification."
    },
    "footer": {
      "text": "Don't have an account?",
      "link": "Sign up"
    }
  },
  "verification": {
    "title": "Verify your account",
    "subtitle": "We've sent a 6-digit code to your email. Please enter it below to verify your account.",
    "fields": {
      "code": {
        "label": "Verification code",
        "placeholder": "123456"
      }
    },
    "submit": "Verify account",
    "submitting": "Verifying…",
    "toast": {
      "loading": "Verifying account…",
      "success": "Account verified successfully! You can now sign in.",
      "error": "Error verifying account: {{error}}"
    },
    "resend": {
      "action": "Resend code",
      "loading": "Resending code…",
      "submitting": "Resending…",
      "success": "New code sent to your email.",
      "error": "Error resending code: {{error}}"
    },
    "footer": {
      "link": "Back to sign in"
    }
  },
  "forgotPassword": {
    "title": "Forgot password?",
    "subtitle": "Enter your email and we'll send you a reset link.",
    "fields": {
      "email": {
        "label": "Email",
        "placeholder": "you@example.com"
      }
    },
    "submit": "Send reset link",
    "submitting": "Sending…",
    "toast": {
      "loading": "Sending reset link…",
      "success": "Reset link sent successfully!",
      "error": "Error sending reset link: {{error}}"
    },
    "success": {
      "title": "Check your email",
      "message": "If an account exists for that address, we've sent a reset link.",
      "action": "Back to sign in"
    },
    "footer": {
      "link": "Back to sign in"
    }
  },
  "validation": {
    "nameMin": "Name must be at least 2 characters",
    "emailInvalid": "Invalid email address",
    "passwordMin": "Password must be at least 8 characters",
    "confirmPasswordRequired": "Please confirm your password",
    "passwordsMatch": "Passwords do not match",
    "passwordRequired": "Password is required",
    "codeLength": "The code must be exactly 6 digits",
    "codeNumeric": "The code must contain only numbers"
  },
  "emailGate": {
    "title": "Pre-sign up",
    "subtitle": "Enter the email you use as a client to continue sign up",
    "fields": {
      "emailGate": {
        "label": "Email",
        "placeholder": "you@example.com"
      }
    },
    "submit": "Continue",
    "submitting": "Checking…",
    "toast": {
      "loading": "Checking email…",
      "success": "Client found — continue to sign up",
      "error": "{{error}}"
    },
    "footer": {
      "text": "Already have an account?",
      "link": "Sign in"
    }
  },
  "errors": {
    "userNotFound": "No client found for that email. Please make sure you are using the same email you signed up with.",
    "invalidCode": "Invalid code. Please try again.",
    "emailAlreadyInUse": "This email is already registered. Please sign in instead."
  }
}
